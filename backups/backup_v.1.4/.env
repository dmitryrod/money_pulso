# ======================
# Настройки окружения
# ======================

# Текущее окружение проекта (production / development)
# Отвечает за отображение документации и пр.
ENVIRONMENT=development

# ======================
# Общие настройки шифррвания
# ======================

# Ключ шифрования, если не заполнить - генерируется автоматиечески
CYPHER_KEY=

# ======================
# Настройки PostgreSQL
# ======================

# Пользователь базы данных
POSTGRES_USER=postgres

# Пароль для пользователя
POSTGRES_PASSWORD=123456789

#Название базы данных
POSTGRES_DB=screener_db

# Хост базы данных
POSTGRES_HOST=postgres

# Порт PostgreSQL
POSTGRES_PORT=5432

# ======================
# Настройки API
# ======================

# Порт приложения (Также привязанный к Docker-контейнеру порт)
APP_PORT=8000

# ======================
# Настройки админки
# ======================

# Имя пользователя
ADMIN_LOGIN=admin

# Пароль для админки
ADMIN_PASSWORD=admin

# ======================
# Телеграм по умолчанию для скринеров
# ======================

# Токен Telegram-бота для отправки сигналов (от @BotFather)
TELEGRAM_BOT_TOKEN=6106449698:AAFQNgbwcPZeqleNWsWN3se0QFmwdm2jLDE

# ID чата/канала, куда слать сигналы (число)
TELEGRAM_CHAT_ID=5732583758

CMC_PRO_API_KEY = 6114ec72-6b6f-4e27-816a-f1a78457e8d3

CMC_UPDATE_TIME = 60 # В минутах

