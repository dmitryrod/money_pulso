# Скопируйте в `.env` и подставьте значения. Секреты в репозиторий не коммитить.

# --- PostgreSQL (и для сервиса postgres в docker-compose, и для приложения) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=screener_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Порт HTTP на хосте (docker-compose: ${APP_PORT}:8000)
APP_PORT=8000

# --- Окружение приложения: development | production ---
ENVIRONMENT=development

# Уровень loguru для app/logs/app.log: TRACE DEBUG INFO SUCCESS WARNING ERROR CRITICAL (невалидное значение → INFO).
# При локальном запуске (без Docker) `app/.env` подхватывается в logger до чтения LOG_LEVEL; уже заданные в ОС переменные не перезаписываются.
# LOG_LEVEL=INFO

# Секрет сессий Starlette (обязательно уникальный в production)
CYPHER_KEY=

# Логин/пароль админки в конфиге (текущий AuthProvider пароль не проверяет — см. app/admin/auth.py)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin

# Опционально: дефолты для Telegram, если не заданы в записи скринера
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Опционально: проверка доступности сети (через запятую URL)
# CONNECTIVITY_PROBE_URLS=https://1.1.1.1/cdn-cgi/trace,https://www.gstatic.com/generate_204

# Опционально: CoinMarketCap Pro API для рангов (достаточно одной переменной)
# X-CMC_PRO_API_KEY=
# CMC_PRO_API_KEY=
# Интервал обновления рангов, в минутах (см. код: значение интерпретируется как минуты)
# X-CMC_UPDATE_TIME=60
# CMC_UPDATE_TIME=60

# Плановый перезапуск WebSocket agg_trades (+ liquidations на фьючерсах), секунды.
# Не задана / пусто → в приложении по умолчанию 14400 (4 ч). Выключить явно: WS_PERIODIC_RECYCLE_SEC=0
# WS_PERIODIC_RECYCLE_SEC=0

# --- Polza AI (Marp / presentations image generation; optional) ---
# POLZA_API_KEY=
# POLZA_AI_API_KEY=
# POLZA_BASE_URL=https://polza.ai/api/v1
# POLZA_MODEL=gpt-image-1

