# Скопируйте в `.env` и подставьте значения. Секреты в репозиторий не коммитить.

# --- PostgreSQL (и для сервиса postgres в docker-compose, и для приложения) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=screener_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Порт HTTP на хосте (docker-compose: ${APP_PORT}:8000)
APP_PORT=8000

# --- Окружение приложения: development | production ---
ENVIRONMENT=development

# Уровень loguru для app/logs/app.log: TRACE DEBUG INFO SUCCESS WARNING ERROR CRITICAL (невалидное значение → INFO).
# При локальном запуске (без Docker) `app/.env` подхватывается в logger до чтения LOG_LEVEL; уже заданные в ОС переменные не перезаписываются.
# LOG_LEVEL=INFO

# Логин/пароль админки в конфиге (текущий AuthProvider пароль не проверяет — см. app/admin/auth.py)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin

ADMIN_DEMO_ENABLED=1
DEMO_LOGIN=DEMO
DEMO_PASSWORD=DEMO
# Подпись cookie сессии; на всех репликах/процессах должен совпадать. Не коммитить реальное значение.
CYPHER_KEY=<длинный случайный>

# Optional: default Telegram for screeners when admin fields are empty.
# If unset or invalid, screeners still run; signals are stored without Telegram delivery.
# TELEGRAM_BOT_TOKEN=          # plain token only — do not prefix with #
# TELEGRAM_CHAT_ID=            # plain integer only (e.g. -1001234567890), not #123

# Опционально: проверка доступности сети (через запятую URL)
# CONNECTIVITY_PROBE_URLS=https://1.1.1.1/cdn-cgi/trace,https://www.gstatic.com/generate_204

# Опционально: CoinMarketCap Pro API для рангов (достаточно одной переменной env)
# Несколько ключей в одной строке через «|» (пробелы у сегментов обрезаются); на каждый HTTP-запрос к CMC выбирается случайный ключ.
# X-CMC_PRO_API_KEY=
# CMC_PRO_API_KEY=
# Интервал обновления рангов, в минутах (по умолчанию в коде — 90). Джиттер ±5% между циклами.
# X-CMC_UPDATE_TIME=90
# CMC_UPDATE_TIME=90
# Размер страницы listings/latest (1…5000; по умолчанию 5000). Меньше — больше запросов подряд с паузой CMC_INTER_PAGE_SLEEP_SEC.
# X-CMC_LISTINGS_PAGE_SIZE=5000
# CMC_LISTINGS_PAGE_SIZE=5000
# Пауза между страницами при пагинации, секунды (снижает риск минутного rate limit при нескольких страницах).
# X-CMC_INTER_PAGE_SLEEP_SEC=1.5
# CMC_INTER_PAGE_SLEEP_SEC=1.5
# Повтор при 429 перед сдачей: число повторов после первой попытки (всего попыток = 1 + CMC_RETRY_MAX).
# X-CMC_RETRY_MAX=5
# CMC_RETRY_MAX=5
# База backoff, сек (если сервер не прислал Retry-After).
# X-CMC_RETRY_BACKOFF_BASE_SEC=2.0
# CMC_RETRY_BACKOFF_BASE_SEC=2.0

# Плановый перезапуск WebSocket agg_trades (+ liquidations на фьючерсах), секунды.
# Не задана / пусто → в приложении по умолчанию 14400 (4 ч). Выключить явно: WS_PERIODIC_RECYCLE_SEC=0
# WS_PERIODIC_RECYCLE_SEC=0

# --- Polza AI (Marp / presentations image generation; optional) ---
# POLZA_API_KEY=
# POLZA_AI_API_KEY=
# POLZA_BASE_URL=https://polza.ai/api/v1
# POLZA_MODEL=gpt-image-1

